# ============================================================
# J.A.R.V.I.S - Environment Configuration
# Copy this file to .env and fill in your API keys
# ============================================================

# ---- GROQ API (Required) ----
# Get your key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: Add more keys for automatic failover
# GROQ_API_KEY_2=your_second_groq_key
# GROQ_API_KEY_3=your_third_groq_key

# ---- GROQ MODEL ----
GROQ_MODEL=llama-3.3-70b-versatile

# ---- TAVILY SEARCH API (Required for Realtime mode) ----
# Get your free key from: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ---- HUGGING FACE (Optional - for embeddings) ----
# Get your key from: https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here

# ---- ASSISTANT PERSONALITY ----
ASSISTANT_NAME=JARVIS
JARVIS_USER_TITLE=Sir

# ---- TEXT TO SPEECH ----
# Run `edge-tts --list-voices` to see all available voices
TTS_VOICE=en-GB-RyanNeural
TTS_RATE=+22%
